# Application
APP_ENV=development
APP_NAME=nepse-trading-bot
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-secure-random-key

# Database (postgresql or sqlite)
DATABASE_URL=sqlite+aiosqlite:///./data/nepse_bot.db
# DATABASE_URL=postgresql+asyncpg://nepse:nepse@localhost:5432/nepse_bot

# Redis (optional)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# Broker TMS — Naasa Securities (Naasa X)
# https://x.naasasecurities.com.np/
BROKER_PROFILE=naasa
BROKER_URL=https://x.naasasecurities.com.np/Home/Dashboard
BROKER_USERNAME=your-email@example.com
BROKER_PASSWORD=your-password
# Not used for Naasa X login (email is used instead)
BROKER_CLIENT_CODE=
BROKER_HEADLESS=true
BROKER_DEBUG_SCREENSHOTS=true
BROKER_SESSION_TIMEOUT_MINUTES=30


# Risk Management
RISK_DAILY_CAPITAL_LIMIT=500000
RISK_MAX_QUANTITY_PER_ORDER=1000
RISK_MAX_EXPOSURE=1000000
RISK_MAX_CONSECUTIVE_FAILURES=5
RISK_KILL_SWITCH=false

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# Encryption key for credential storage (Fernet key)
CREDENTIAL_ENCRYPTION_KEY=
